generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  name                String
  encryptedPassword   String
  phoneNumber         String?
  hasProfile          Boolean           @default(false)
  role                ROLE
  hasRequest          Boolean           @default(false)
  provider            Provider?         @default(local)
  customerProfile     CustomerProfile?
  estimatesAsCustomer Estimate[]        @relation("estimateCustomer")
  estimatesAsWorker   Estimate[]        @relation("estimateWorker")
  estimateRequests    EstimateRequest[]
  customerFavorites   Favorite[]        @relation("customerFavorites")
  workerFavorites     Favorite[]        @relation("workerFavorites")
  Notification        Notification[]
  writtenReviews      Review[]          @relation("customerReview")
  receivedReviews     Review[]          @relation("workerReview")
  workProfile         WorkerProfile?
}

model WorkerProfile {
  id           String        @id @default(uuid())
  profileImage String?
  nickname     String
  experience   Int
  summary      String
  description  String
  services     ServiceType[]
  serviceAreas Area[]
  workerId     String        @unique
  user         User          @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model CustomerProfile {
  id           String        @id @default(uuid())
  profileImage String?
  customerId   String        @unique
  livingArea   Area
  services     ServiceType[]
  user         User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(uuid())
  workerId   String
  customerId String
  star       Int
  createdAt  DateTime @default(now())
  content    String
  estimateId String   @unique
  customer   User     @relation("customerReview", fields: [customerId], references: [id])
  estimate   Estimate @relation(fields: [estimateId], references: [id])
  worker     User     @relation("workerReview", fields: [workerId], references: [id])
}

model Favorite {
  id         String @id @default(uuid())
  customerId String
  workerId   String
  customer   User   @relation("customerFavorites", fields: [customerId], references: [id])
  worker     User   @relation("workerFavorites", fields: [workerId], references: [id])

  @@unique([customerId, workerId])
}

model EstimateRequest {
  id            String                @id @default(uuid())
  customerId    String
  movingDate    DateTime
  destination   String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now())
  status        EstimateRequestStatus @default(active)
  serviceType   ServiceType
  departureArea Area
  departure     String
  estimates     Estimate[]
  user          User                  @relation(fields: [customerId], references: [id])
}

model Estimate {
  id                String          @id @default(uuid())
  estimateRequestId String
  customerId        String
  workerId          String
  movingDate        DateTime
  destination       String
  price             Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now())
  rejectionMessage  String?
  status            EstimateStatus
  comment           String?
  serviceType       ServiceType
  isConfirmed       Boolean         @default(false)
  userId            String?
  departureArea     Area
  departure         String
  customer          User            @relation("estimateCustomer", fields: [customerId], references: [id])
  estimateRequset   EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
  worker            User            @relation("estimateWorker", fields: [workerId], references: [id])
  review            Review?
}

model Notification {
  id        String   @id @default(uuid())
  isRead    Boolean
  message   String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum ROLE {
  customer
  worker
}

enum Area {
  seoul
  gyeonggi
  incheon
  gangwon
  chungbuk
  chungnam
  sejong
  daejeon
  jeonbuk
  jeonnam
  gwangju
  gyeongbuk
  gyeongnam
  daegu
  ulsan
  busan
  jeju
}

enum ServiceType {
  smallMove
  homeMove
  officeMove
}

enum EstimateStatus {
  general
  assigned
  rejected
}

enum EstimateRequestStatus {
  active
  inactive
  confirmed
}

enum Provider {
  google
  kakao
  naver
  local
}
