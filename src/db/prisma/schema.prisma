generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  name              String
  encryptedPassword String
  phoneNumber       String?
  hasProfile        Boolean           @default(false)
  role              ROLE
  estimateRequests  EstimateRequest[]
  favorite          Favorite[]
  customerProfile   CustomerProfile?
  reviews            Review[]
  workProfile       WorkerProfile?
}

model WorkerProfile {
  id           String        @id @default(uuid())
  profileImage String?
  nickname     String?
  experience   Int
  summary      String
  description  String
  services     ServiceType[]
  serviceAreas Area[]
  workerId     String        @unique
  user         User          @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model CustomerProfile {
  id           String        @id @default(uuid())
  profileImage String?
  customerId   String        @unique
  livingArea   Area
  services     ServiceType[]
  user         User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// 견적이랑 추가
model Review {
  id         String   @id @default(uuid())
  workerId   String
  customerId String
  star       Int
  createdAt  DateTime @default(now())
  content    String
  estimate   Estimate @relation(fields: [estimateId], references: [id])
  user       User     @relation(fields: [workerId], references: [id])
  estimateId String
}

model Favorite {
  id         String @id @default(uuid())
  customerId String
  workerId   String
  user       User   @relation(fields: [customerId], references: [id])
}

model EstimateRequest {
  id          String                @id @default(uuid())
  customerId  String
  serviceType ServiceType
  movingDate  DateTime
  departure   String
  destination String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @default(now())
  status      EstimateRequestStatus @default(active)
  estimates   Estimate[]
  user        User                  @relation(fields: [customerId], references: [id])
}

model Estimate {
  id                String          @id @default(uuid())
  estimateRequestId String
  customerId        String
  workerId          String
  serviceType       ServiceType
  movingDate        DateTime
  departure         String
  destination       String
  price             Int?
  isCompleted       Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now())
  rejectionMessage  String?
  status            EstimateStatus
  comment           String?
  estimateRequset   EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
  reviews            Review[]
}

enum ROLE {
  customer
  worker
}

enum Area {
  seoul
  gyeonggi
  incheon
  gangwon
  chungbuk
  chungnam
  sejong
  daejeon
  jeonbuk
  jeonnam
  gwangju
  gyeongbuk
  gyeongnam
  daegu
  ulsan
  busan
  jeju
}

enum ServiceType {
  smallMove
  homeMove
  officeMove
}

enum EstimateStatus {
  general
  assigned
  rejected
}

enum EstimateRequestStatus {
  active
  inactive
  confirmed
}
